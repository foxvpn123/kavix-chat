{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and presence information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "lastSeen": { "type": "number" },
        "isOnline": { "type": "boolean" },
        "avatarColor": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderColor": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "type": { "type": "string", "enum": ["text", "image"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["senderId", "senderName", "text", "timestamp"]
    },
    "Presence": {
      "title": "Presence",
      "description": "Real-time presence tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "lastActive": { "type": "number" }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Metadata for a chat between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "lastSender": { "type": "string" },
        "updatedAt": { "type": "number" },
        "unreadCounts": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/users/{handle}": {
      "schema": "User",
      "description": "Users keyed by their unique permanent handle"
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Metadata for a private chat"
    },
    "/conversations/{convId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Physical messages in a conversation"
    },
    "/presence/{handle}": {
      "schema": "Presence",
      "description": "Global presence tracking"
    }
  }
}
